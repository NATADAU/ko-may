    {label:'Занятия 2024–25',  data:l24,backgroundColor:'rgba(248,166,0,.7)',borderRadius:3,borderSkipped:false},
    {label:'Занятия 2025–26',  data:l25,backgroundColor:'rgba(4,166,52,.75)',borderRadius:3,borderSkipped:false},
  ]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:tkc,boxWidth:14,font:{size:14}}},tooltip:tip},scales:scale()}
});
const barMap={y24:[0,2],y25:[1,3],pr:[0,1],ls:[2,3]};
function toggleBar(k,btn){ btn.classList.toggle('on'); const on=btn.classList.contains('on'); barMap[k].forEach(i=>{cBar.data.datasets[i].hidden=!on;}); cBar.update(); }

/* ─── CHART 3: тренд ─── */
function trend(a){
  const n=a.length,sx=n*(n-1)/2,sx2=(n-1)*n*(2*n-1)/6,sy=a.reduce((s,v)=>s+v,0),sxy=a.reduce((s,v,i)=>s+v*i,0);
  const m=(n*sxy-sx*sy)/(n*sx2-sx*sx),b=(sy-m*sx)/n;
  return a.map((_,i)=>Math.round(m*i+b));
}
const cTrend=new Chart(ctx('cTrend'),{
  type:'line',
  data:{labels:M,datasets:[
    {label:'Факт 2024–25', data:t24,borderColor:'rgba(98,98,97,.65)',borderWidth:2,pointRadius:3,tension:.4,fill:false},
    {label:'Тренд 2024–25',data:trend(t24),borderColor:'rgba(98,98,97,.4)',borderDash:[7,4],borderWidth:1.5,pointRadius:0,fill:false},
    {label:'Факт 2025–26', data:t25,borderColor:'#019BAB',borderWidth:2.5,pointRadius:4,pointBackgroundColor:'#019BAB',tension:.4,fill:false},
    {label:'Тренд 2025–26',data:trend(t25),borderColor:'rgba(91,190,201,.65)',borderDash:[7,4],borderWidth:1.5,pointRadius:0,fill:false},
  ]},
  options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{labels:{color:tkc,boxWidth:14,font:{size:14}}},tooltip:tip},scales:scale()}
});
function toggleTrendLine(idxs,btn){ btn.classList.toggle('on'); const on=btn.classList.contains('on'); idxs.forEach(i=>{cTrend.data.datasets[i].hidden=!on;}); cTrend.update(); }

/* ─── CHART 4: НОВОЕ — Δ первичного ─── */
const deltaP = p24.map((v,i)=>Math.round((p25[i]-v)/v*100));
const cDelta=new Chart(ctx('cDelta'),{
  type:'bar',
  data:{labels:M,datasets:[{
    label:'Δ% первичного',
    data:deltaP,
    backgroundColor:deltaP.map(v=>v>=0?'rgba(4,166,52,.75)':'rgba(229,0,79,.65)'),
    borderRadius:4,
    borderSkipped:false,
  }]},
  options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{display:false},tooltip:{...tip,callbacks:{label:ctx=>`${ctx.raw>0?'+':''}${ctx.raw}%`}}},
    scales:{
      x:{grid:{color:grd},ticks:{color:tkc,font:{size:14}}},
      y:{grid:{color:grd},ticks:{color:tkc,font:{size:14},callback:v=>`${v>0?'+':''}${v}%`},
        afterDataLimits:scale=>{scale.min=Math.min(scale.min,-5);scale.max=Math.max(scale.max,5);}
      }
    }
  }
});

/* ─── TABLE COLUMN FILTER ─── */
function toggleCols(cls,btn){
  btn.classList.toggle('on');
  const on=btn.classList.contains('on');
  document.querySelectorAll('.'+cls).forEach(el=>{ el.style.display=on?'':'none'; });
}
</script>
