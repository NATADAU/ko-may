<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Контрактный отдел — май 2026</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --teal:  #019BAB;
  --teal2: #5BBEC9;
  --teal3: #C7E9ED;
  --pink:  #E5004F;
  --pink2: #EA496D;
  --yel:   #F8A600;
  --grn:   #04A634;
  --grn2:  #89BD1E;
  --bg:    #F8F8F8;
  --white: #FFFFFF;
  --grey:  #626261;
  --black: #2A2A2A;
  --brd:   #D8EDEF;
  --r:     14px;
}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes countUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

*{box-sizing:border-box;margin:0;padding:0;}
body{background:linear-gradient(160deg,#f0fafb 0%,#f8f8f8 60%,#fdf0f5 100%);background-attachment:fixed;color:var(--black);font-family:'Segoe UI',system-ui,sans-serif;font-size:16px;min-height:100vh;}

/* HEADER */
.hdr{background:linear-gradient(120deg,#017a87 0%,var(--teal) 40%,var(--teal2) 100%);padding:0 20px;position:sticky;top:0;z-index:200;box-shadow:0 4px 24px rgba(1,155,171,.4);}
.hdr-inner{display:flex;align-items:center;justify-content:space-between;padding:16px 0 0;flex-wrap:wrap;gap:8px;}
.hdr h1{font-size:clamp(1.05rem,3.5vw,1.45rem);font-weight:700;color:#fff;letter-spacing:-.01em;}
.hdr-sub{font-size:.88rem;color:rgba(255,255,255,.8);margin-top:3px;}
.badge{background:linear-gradient(135deg,rgba(255,255,255,.3),rgba(255,255,255,.15));border:1px solid rgba(255,255,255,.5);border-radius:20px;padding:5px 16px;font-size:.88rem;color:#fff;font-weight:700;white-space:nowrap;backdrop-filter:blur(4px);}
.hdr-right{display:flex;align-items:center;gap:12px;flex-shrink:0;}
.tabs{display:flex;overflow-x:auto;scrollbar-width:none;margin-top:12px;}
.tabs::-webkit-scrollbar{display:none;}
.tab-btn{background:none;border:none;border-bottom:3px solid transparent;color:rgba(255,255,255,.7);cursor:pointer;font-size:1rem;font-family:inherit;font-weight:500;padding:10px 22px;transition:.25s;white-space:nowrap;}
.tab-btn:hover{color:#fff;}
.tab-btn.active{color:#fff;border-bottom-color:#fff;}
.burger{display:none;background:none;border:none;cursor:pointer;padding:4px;flex-shrink:0;}
.burger span{display:block;width:26px;height:2.5px;background:#fff;margin:5px 0;border-radius:2px;transition:.3s;}
.burger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg);}
.burger.open span:nth-child(2){opacity:0;}
.burger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);}
.mob-menu{display:none;position:fixed;inset:0;background:linear-gradient(160deg,#017a87,var(--teal),var(--teal2));z-index:190;flex-direction:column;align-items:center;justify-content:center;}
.mob-menu.open{display:flex;}
.mob-btn{background:none;border:none;border-bottom:1px solid rgba(255,255,255,.18);color:rgba(255,255,255,.75);cursor:pointer;font-size:1.5rem;font-family:inherit;font-weight:600;padding:18px 0;width:80%;text-align:center;transition:.2s;}
.mob-btn:last-child{border-bottom:none;}
.mob-btn.active,.mob-btn:hover{color:#fff;}
.mob-btn.active{color:var(--teal3);}

/* MAIN */
main{max-width:960px;margin:0 auto;padding:24px 16px 70px;}
.tab-panel{display:none;}
.tab-panel.active{display:block;animation:fadeIn .35s ease;}

.sec{font-size:.8rem;text-transform:uppercase;letter-spacing:.1em;color:var(--grey);margin:28px 0 14px;display:flex;align-items:center;gap:10px;}
.sec::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,var(--brd),transparent);}
.sec:first-child{margin-top:6px;}

/* KPI CARDS */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(195px,1fr));gap:14px;margin-bottom:18px;}
.card{background:var(--white);border:1px solid var(--brd);border-radius:var(--r);padding:22px 20px;border-top:4px solid transparent;transition:transform .2s,box-shadow .2s;animation:fadeUp .4s ease both;}
.card:nth-child(1){animation-delay:.05s}.card:nth-child(2){animation-delay:.12s}.card:nth-child(3){animation-delay:.19s}
.card:nth-child(4){animation-delay:.26s}.card:nth-child(5){animation-delay:.33s}.card:nth-child(6){animation-delay:.40s}
.card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(1,155,171,.13);}
.card.ct{border-top-color:var(--teal);background:linear-gradient(160deg,#fff 70%,#f0fafb 100%);}
.card.cp{border-top-color:var(--pink);background:linear-gradient(160deg,#fff 70%,#fff0f4 100%);}
.card.cg{border-top-color:var(--grn);background:linear-gradient(160deg,#fff 70%,#f0fdf4 100%);}
.card-lbl{font-size:.82rem;color:var(--grey);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px;}
.card-val{font-size:2.8rem;font-weight:700;line-height:1;letter-spacing:-.03em;}
.vt{color:var(--teal);}.vp{color:var(--pink);}.vg{color:var(--grn);}
.card-sub{font-size:.85rem;color:var(--grey);margin-top:7px;}
.delta{font-size:.88rem;font-weight:700;margin-top:10px;}
.du{color:var(--grn);}.dd{color:var(--pink);}

/* --- НОВОЕ: мини-спарклайн в карточке --- */
.sparkwrap{margin-top:12px;height:36px;position:relative;}
.sparkwrap canvas{width:100%!important;height:36px!important;}

/* FILTER ROW */
.frow{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;align-items:center;}
.flbl{font-size:.85rem;color:var(--grey);font-weight:600;white-space:nowrap;}
.fbtn{background:var(--white);border:1.5px solid var(--brd);border-radius:8px;color:var(--grey);cursor:pointer;font-family:inherit;font-size:.85rem;font-weight:500;padding:7px 15px;transition:.2s;}
.fbtn:hover{border-color:var(--teal2);transform:translateY(-1px);}
.fbtn.on{background:linear-gradient(135deg,var(--teal),var(--teal2));border-color:var(--teal);color:#fff;box-shadow:0 3px 12px rgba(1,155,171,.3);}
.fbtn.on.pink{background:linear-gradient(135deg,var(--pink),var(--pink2));border-color:var(--pink);box-shadow:0 3px 12px rgba(229,0,79,.25);}
.fbtn.on.grn{background:linear-gradient(135deg,var(--grn),var(--grn2));border-color:var(--grn);box-shadow:0 3px 12px rgba(4,166,52,.25);}

/* CHART CARD */
.ccrd{background:var(--white);border:1px solid var(--brd);border-radius:var(--r);padding:22px;margin-bottom:14px;box-shadow:0 2px 12px rgba(1,155,171,.06);animation:fadeUp .4s ease both;}
.ccrd h3{font-size:1.02rem;font-weight:700;margin-bottom:4px;}
.ccrd .cs{font-size:.85rem;color:var(--grey);margin-bottom:14px;}
.cwrap{position:relative;height:250px;}
.leg{display:flex;gap:20px;flex-wrap:wrap;margin-bottom:14px;}
.li{display:flex;align-items:center;gap:9px;font-size:1rem;color:var(--black);font-weight:500;}
.ld{width:13px;height:13px;border-radius:50%;flex-shrink:0;}

/* --- НОВОЕ: инфо-полоса под графиком --- */
.chart-note{font-size:.82rem;color:var(--grey);margin-top:10px;padding:8px 12px;background:#f5fbfc;border-radius:8px;border-left:3px solid var(--teal2);}

/* TABLE */
.twrap{background:var(--white);border:1px solid var(--brd);border-radius:var(--r);overflow:hidden;margin-bottom:14px;box-shadow:0 2px 16px rgba(1,155,171,.07);animation:fadeUp .35s ease both;}
.thdr{padding:18px 20px 12px;border-bottom:1px solid var(--brd);background:linear-gradient(90deg,#f5fbfc,#fff);}
.thdr h3{font-size:1.02rem;font-weight:700;}
.thdr p{font-size:.85rem;color:var(--grey);margin-top:3px;}
.tscroll{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:.92rem;}
thead th{background:linear-gradient(180deg,#e4f5f8,#d8eef2);color:var(--grey);font-size:.77rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;padding:10px 14px;text-align:center;border-bottom:2px solid var(--brd);}
thead th:first-child{text-align:left;padding-left:20px;}
tbody tr{transition:background .15s;}
tbody tr:hover{background:linear-gradient(90deg,#f0f9fb,#f8feff);}
tbody tr:not(:last-child) td{border-bottom:1px solid var(--brd);}
tbody td{padding:12px 14px;text-align:center;font-size:.94rem;}
tbody td:first-child{text-align:left;padding-left:20px;color:var(--grey);font-weight:500;}
.cdiv{border-left:1px solid var(--brd);}
.tn{font-weight:600;}.tt{color:var(--teal);font-weight:700;}.tp{color:var(--pink);font-weight:700;}.tgg{color:var(--grn);font-weight:700;}
tr.cur{background:linear-gradient(90deg,#daf2f6,#e8f8fb);}
tr.cur td:first-child{color:var(--black);font-weight:700;}

/* --- НОВОЕ: столбец Δ в таблице --- */
.tdelta{font-size:.8rem;font-weight:700;padding:12px 8px;}
.tdg{color:var(--grn);}.tdp{color:var(--pink);}

/* CONCLUSIONS */
.conc{background:var(--white);border:1px solid var(--brd);border-radius:var(--r);padding:24px;margin-bottom:14px;box-shadow:0 2px 14px rgba(1,155,171,.06);transition:box-shadow .25s,transform .25s;animation:fadeUp .4s ease both;}
.conc:nth-child(2){animation-delay:.06s}.conc:nth-child(3){animation-delay:.12s}.conc:nth-child(4){animation-delay:.18s}
.conc:nth-child(5){animation-delay:.24s}.conc:nth-child(6){animation-delay:.30s}
.conc:hover{box-shadow:0 6px 28px rgba(1,155,171,.14);transform:translateY(-2px);}
.conc h3{font-size:1.02rem;font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.tag{font-size:.82rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase;padding:4px 13px;border-radius:20px;}
.tagt{background:#c7e9ed;color:#014f57;}
.tagg{background:#b8edca;color:#015e1e;}
.tagp{background:#f9c4d4;color:#8b0030;}
.conc-body{font-size:1.05rem;line-height:1.9;color:var(--grey);}
.conc-body strong{color:var(--black);font-weight:700;}
.srow{display:flex;gap:10px;margin:14px 0;flex-wrap:wrap;}
.spill{background:linear-gradient(145deg,#f4fbfc,#edf7f9);border:1px solid var(--brd);border-radius:9px;padding:10px 18px;font-size:1rem;color:var(--grey);line-height:1.35;transition:transform .2s,box-shadow .2s;min-width:fit-content;}
.spill:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(1,155,171,.12);}
.spill span{font-weight:700;font-size:1.45rem;display:block;}
.st{color:var(--teal);}.sg{color:var(--grn);}.sp{color:var(--pink);}

/* --- НОВОЕ: прогресс-бар годового разрыва --- */
.gap-bar-wrap{margin:14px 0;}
.gap-bar-lbl{display:flex;justify-content:space-between;font-size:.85rem;color:var(--grey);margin-bottom:6px;}
.gap-bar-track{background:#f0f0f0;border-radius:8px;height:12px;overflow:hidden;}
.gap-bar-fill{height:12px;border-radius:8px;transition:width 1s ease;}

/* RESPONSIVE */
@media(max-width:620px){
  .burger{display:block;}.tabs{display:none;}.hdr-inner{padding-bottom:14px;}
  .cards{grid-template-columns:1fr 1fr;}
  main{padding:16px 12px 60px;}.cwrap{height:200px;}
}
@media(max-width:360px){.cards{grid-template-columns:1fr;}}
</style>
</head>
<body>

<div class="hdr">
  <div class="hdr-inner">
    <div style="display:flex;align-items:center;gap:14px;">
      <img src="data:image/png;base64," alt="Логотип ЦЛП" style="width:52px;height:52px;border-radius:50%;border:2px solid rgba(255,255,255,.4);flex-shrink:0;object-fit:cover;">
      <div>
        <h1>Контрактный отдел — май 2026</h1>
        <div class="hdr-sub">Учебный год 2025–26 · сентябрь – май</div>
      </div>
    </div>
    <div class="hdr-right">
      <div class="badge">438 чел.</div>
      <button class="burger" id="brgBtn" aria-label="Меню"><span></span><span></span><span></span></button>
    </div>
  </div>
  <nav class="tabs" id="deskTabs">
    <button class="tab-btn" data-tab="overview">Обзор</button>
    <button class="tab-btn" data-tab="dynamics">Динамика</button>
    <button class="tab-btn" data-tab="table">Таблица</button>
    <button class="tab-btn active" data-tab="conclusions">Выводы</button>
  </nav>
</div>

<div class="mob-menu" id="mobMenu">
  <button class="mob-btn" data-tab="overview">Обзор</button>
  <button class="mob-btn" data-tab="dynamics">Динамика</button>
  <button class="mob-btn" data-tab="table">Таблица</button>
  <button class="mob-btn active" data-tab="conclusions">Выводы</button>
</div>

<main>

<!-- ══ ОБЗОР ══ -->
<div class="tab-panel" id="tab-overview">
  <div class="sec">Май 2026 — текущий месяц</div>
  <div class="cards">
    <div class="card cg">
      <div class="card-lbl">Первичный приём</div>
      <div class="card-val vg">51</div>
      <div class="card-sub">май 2026</div>
      <div class="delta du">▲ +24% к маю 2025 (41)</div>
      <div class="sparkwrap"><canvas id="spPrim"></canvas></div>
    </div>
    <div class="card ct">
      <div class="card-lbl">Занятия и консультации</div>
      <div class="card-val vt">387</div>
      <div class="card-sub">май 2026</div>
      <div class="delta du">▲ +4% к маю 2025 (371)</div>
      <div class="sparkwrap"><canvas id="spLess"></canvas></div>
    </div>
    <div class="card cg">
      <div class="card-lbl">Всего детей</div>
      <div class="card-val vg">438</div>
      <div class="card-sub">май 2026</div>
      <div class="delta du">▲ +6% к маю 2025 (412)</div>
      <div class="sparkwrap"><canvas id="spTot"></canvas></div>
    </div>
  </div>

  <div class="sec">Итоги учебного года · сентябрь – май 2025–26</div>
  <div class="cards">
    <div class="card ct">
      <div class="card-lbl">Первичных приёмов за год</div>
      <div class="card-val" style="font-size:2.2rem">557</div>
      <div class="card-sub">сент–май · первичный приём</div>
      <div class="delta dd">▼ −6% (было 594 в 2024–25)</div>
    </div>
    <div class="card ct">
      <div class="card-lbl">Среднее занятий / мес</div>
      <div class="card-val" style="font-size:2.2rem">397</div>
      <div class="card-sub">сент–май 2025–26</div>
      <div class="delta du">▲ +1% (было 394)</div>
    </div>
    <div class="card ct">
      <div class="card-lbl">Среднее всего / мес</div>
      <div class="card-val" style="font-size:2.2rem">459</div>
      <div class="card-sub">сент–май 2025–26</div>
      <div class="delta" style="color:var(--grey)">≈ 0% (было 460)</div>
    </div>
  </div>

  <!-- ИСТОРИЯ ГОДА: путь первичного приёма -->
  <div class="sec">Первичный приём: путь учебного года</div>
  <div class="ccrd" style="padding:24px 22px 20px;">
    <div style="font-size:1rem;color:var(--grey);margin-bottom:20px;line-height:1.6;">
      Год начался уверенно, провалился в ноябре и медленно восстановился к финишу. В мае — первый уверенный плюс за полгода.
    </div>
    <div style="overflow-x:auto;">
      <svg id="journeySvg" viewBox="0 0 820 200" xmlns="http://www.w3.org/2000/svg" style="width:100%;min-width:560px;display:block;">
        <defs>
          <linearGradient id="pathGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%"   stop-color="#E5004F" stop-opacity="0.7"/>
            <stop offset="55%"  stop-color="#E5004F" stop-opacity="0.7"/>
            <stop offset="75%"  stop-color="#F8A600" stop-opacity="0.9"/>
            <stop offset="100%" stop-color="#04A634" stop-opacity="1"/>
          </linearGradient>
          <!-- маркер стрелки -->
          <marker id="arr" markerWidth="8" markerHeight="8" refX="4" refY="4" orient="auto">
            <path d="M1,1 L7,4 L1,7 Z" fill="#04A634"/>
          </marker>
        </defs>

        <!-- нулевая линия -->
        <line x1="30" y1="90" x2="790" y2="90" stroke="#e0e0e0" stroke-width="1" stroke-dasharray="4,4"/>
        <text x="18" y="94" font-size="11" fill="#bbb" text-anchor="middle">0</text>

        <!-- путь (нарисован как polyline, анимируется через stroke-dashoffset) -->
        <!-- точки: Сен+14, Окт+1, Ноя-52, Дек-7, Янв+22, Фев-7, Мар+17, Апр-17, Май+24 -->
        <!-- y = 90 - value*1.1  (масштаб: 1% = 1.1px, нулевая линия y=90) -->
        <!-- Сен:90-15=75  Окт:90-1=89  Ноя:90+57=147  Дек:90+8=98  Янв:90-24=66  Фев:90+8=98  Мар:90-19=71  Апр:90+19=109  Май:90-26=64 -->
        <polyline id="journeyPath"
          points="90,75 180,89 270,147 360,98 450,66 540,98 630,71 720,109 795,64"
          fill="none"
          stroke="url(#pathGrad)"
          stroke-width="3.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="stroke-dasharray:1400;stroke-dashoffset:1400;transition:stroke-dashoffset 2s cubic-bezier(.4,0,.2,1)"/>

        <!-- точки-узлы (появляются после линии) -->
        <!-- Сен +14% зелёный -->
        <circle cx="90"  cy="75"  r="7" fill="#04A634" opacity="0" class="jdot" style="transition:opacity .3s .4s"/>
        <!-- Окт +1% жёлтый -->
        <circle cx="180" cy="89"  r="7" fill="#F8A600" opacity="0" class="jdot" style="transition:opacity .3s .6s"/>
        <!-- Ноя -52% красный большой -->
        <circle cx="270" cy="147" r="9" fill="#E5004F" opacity="0" class="jdot" style="transition:opacity .3s .9s"/>
        <!-- Дек -7% красный -->
        <circle cx="360" cy="98"  r="7" fill="#E5004F" opacity="0" class="jdot" style="transition:opacity .3s 1.1s"/>
        <!-- Янв +22% зелёный -->
        <circle cx="450" cy="66"  r="7" fill="#04A634" opacity="0" class="jdot" style="transition:opacity .3s 1.3s"/>
        <!-- Фев -7% красный -->
        <circle cx="540" cy="98"  r="7" fill="#E5004F" opacity="0" class="jdot" style="transition:opacity .3s 1.5s"/>
        <!-- Мар +17% зелёный -->
        <circle cx="630" cy="71"  r="7" fill="#04A634" opacity="0" class="jdot" style="transition:opacity .3s 1.7s"/>
        <!-- Апр -17% красный -->
        <circle cx="720" cy="109" r="7" fill="#E5004F" opacity="0" class="jdot" style="transition:opacity .3s 1.9s"/>
        <!-- Май +24% зелёный большой со звездой-обводкой -->
        <circle cx="795" cy="64"  r="10" fill="#04A634" opacity="0" class="jdot" style="transition:opacity .3s 2.1s"/>
        <circle cx="795" cy="64"  r="15" fill="none" stroke="#04A634" stroke-width="2" opacity="0" class="jdot" style="transition:opacity .3s 2.2s"/>

        <!-- подписи месяцев -->
        <text x="90"  y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Сен</text>
        <text x="180" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Окт</text>
        <text x="270" y="188" text-anchor="middle" font-size="12.5" fill="#E5004F" font-weight="700" font-family="'Segoe UI',sans-serif">Ноя</text>
        <text x="360" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Дек</text>
        <text x="450" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Янв</text>
        <text x="540" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Фев</text>
        <text x="630" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Мар</text>
        <text x="720" y="188" text-anchor="middle" font-size="12.5" fill="#626261" font-family="'Segoe UI',sans-serif">Апр</text>
        <text x="795" y="188" text-anchor="middle" font-size="12.5" fill="#04A634" font-weight="700" font-family="'Segoe UI',sans-serif">Май ★</text>

        <!-- значения над/под точками (появляются с точками) -->
